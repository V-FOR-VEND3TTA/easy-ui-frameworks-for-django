# ============================================
# DUFS MASTER .gitignore
# Covers: Django, Python, React/Node, Vite,
#         IDEs, OS files, and packaging artifacts
# ============================================

# ─── PYTHON / DJANGO ───────────────────────

# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Django local settings and secrets
*.env
local_settings.py
settings/local.py

# Database
*.sqlite3
*.sqlite3-journal

# Static files collected in production
/staticfiles/
/media/

# Django migrations (optional: keep initial, ignore auto-generated)
# Uncomment the next line ONLY if you want to ignore all migrations
# */migrations/*.py
# */migrations/__init__.py

# ─── NODE / REACT ──────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs (Module F: Vite build to Django static)
frontend/static/dufs-react/
frontend-spa/dist/
frontend-spa/build/

# Vite cache
.vite/
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── TESTING / COVERAGE ────────────────────

htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ─── IDEs / EDITORS ────────────────────────

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# ─── OS FILES ──────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# Linux
.directory
.Trash-*

# ─── MISCELLANEOUS ─────────────────────────

# Temporary files
*.tmp
*.temp
*.log

# Backup files
*.bak
*.backup

# Lock files (optional — commit one, ignore others)
# package-lock.json   # npm — commit this for reproducibility
# yarn.lock           # yarn — commit this
# pnpm-lock.yaml      # pnpm — commit this
# poetry.lock         # Poetry — commit this
# Pipfile.lock        # Pipenv — commit this

# ─── DUFS SPECIFIC ─────────────────────────

# Ignore generated templates during local testing
# (uncomment if you want to prevent accidental commits
#  of templates generated by `python manage.py generate_ui`)
# templates/registration/*.html
# templates/base.html
# templates/profile.html

# Local docs builds
docs/_build/
site/
